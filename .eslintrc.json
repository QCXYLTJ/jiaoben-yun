{
	"extends": "eslint:recommended",
	"env": {
		"browser": true,
		"es6": true,
		"node": true,
		"serviceworker": true,
		"worker": true
	},
	"rules": {
		"no-constant-condition": [
			"error",
			{
				"checkLoops": false
			}
		],
		"no-irregular-whitespace": [
			"error",
			{
				"skipStrings": true,
				"skipTemplates": true
			}
		]
	},
	"parserOptions": {
		"ecmaVersion": 13,
		"sourceType": "module"
	}
}